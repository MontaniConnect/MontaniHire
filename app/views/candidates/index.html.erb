<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
  <h1 style="margin: 0;">Recruitment Pipeline</h1>
  <%= link_to "+ Upload CV", cv_analyses_path, class: "btn" %>
</div>

<%# ── Interview schedule panel ── %>
<% if @today_bookings.any? || @upcoming_bookings.any? %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">

    <%# Today column %>
    <div class="card" style="padding: 1rem 1.25rem;">
      <div style="font-size: 0.7rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Today</div>
      <% if @today_bookings.any? %>
        <% @today_bookings.each_with_index do |booking, i| %>
          <div style="<%= i > 0 ? 'border-top: 1px solid #f0f0f0; padding-top: 0.65rem; margin-top: 0.65rem;' : '' %>">
            <%= render "candidates/interview_card", booking: booking %>
          </div>
        <% end %>
      <% else %>
        <p style="font-size: 0.85rem; color: #bbb; margin: 0;">No interviews today.</p>
      <% end %>
    </div>

    <%# Next 7 days column %>
    <div class="card" style="padding: 1rem 1.25rem;">
      <div style="font-size: 0.7rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem;">Next 7 Days</div>
      <% if @upcoming_bookings.any? %>
        <% @upcoming_bookings.each_with_index do |booking, i| %>
          <div style="<%= i > 0 ? 'border-top: 1px solid #f0f0f0; padding-top: 0.65rem; margin-top: 0.65rem;' : '' %>">
            <%= render "candidates/interview_card", booking: booking %>
          </div>
        <% end %>
      <% else %>
        <p style="font-size: 0.85rem; color: #bbb; margin: 0;">No upcoming interviews.</p>
      <% end %>
    </div>

  </div>
<% end %>

<%# Search + filter bar %>
<%= form_with url: candidates_path, method: :get do |f| %>
  <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; align-items: center; flex-wrap: nowrap;">
    <div style="position: relative; flex: 1;">
      <input type="text" name="q" value="<%= @q %>"
             placeholder="Search by name…"
             style="width: 100%; padding: 0.55rem 0.75rem 0.55rem 2rem;
                    border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; outline: none;">
      <span style="position: absolute; left: 0.6rem; top: 50%; transform: translateY(-50%);
                   font-size: 0.9rem; color: #aaa; pointer-events: none;">🔍</span>
    </div>
    <% if @clients.any? %>
      <select name="client_id"
              onchange="this.form.job_role_id.value=''; this.form.submit();"
              style="padding: 0.55rem 0.75rem; border: 1px solid #ddd; border-radius: 6px;
                     font-size: 0.9rem; background: #fff; color: #555; outline: none; width: 180px; flex-shrink: 0;">
        <option value="">All clients</option>
        <% @clients.each do |c| %>
          <option value="<%= c.id %>" <%= "selected" if @client_id == c.id.to_s %>>
            <%= c.name %>
          </option>
        <% end %>
      </select>
    <% end %>
    <% if @job_roles.any? %>
      <select name="job_role_id"
              style="padding: 0.55rem 0.75rem; border: 1px solid #ddd; border-radius: 6px;
                     font-size: 0.9rem; background: #fff; color: #555; outline: none; width: 200px; flex-shrink: 0;">
        <option value="">All job roles</option>
        <% @job_roles.each do |jr| %>
          <option value="<%= jr.id %>" <%= "selected" if @job_role_id == jr.id.to_s %>>
            <%= jr.title %>
          </option>
        <% end %>
      </select>
    <% end %>
    <%= f.submit "Filter", class: "btn", style: "padding: 0.55rem 1rem; font-size: 0.9rem; flex-shrink: 0;" %>
    <% if @q.present? || @job_role_id.present? || @client_id.present? %>
      <%= link_to "Clear", candidates_path,
            style: "padding: 0.55rem 0.75rem; font-size: 0.9rem; color: #555; text-decoration: none;
                    border: 1px solid #ddd; border-radius: 6px; background: #fff; flex-shrink: 0;" %>
    <% end %>
  </div>
<% end %>

<% grouped    = @candidates.reject(&:final_interview_no_show?).group_by(&:pipeline_stage) %>
<%
  _cv_rec_labels = { "high_match" => "High Match", "moderate_match" => "Moderate Match", "low_match" => "Low Match" }
  _ep_rec_labels = { "comprehensive" => "Comprehensive", "substantive" => "Substantive", "superficial" => "Superficial" }
  _rec_tc = { "high_match" => "#166534", "moderate_match" => "#854d0e", "low_match" => "#991b1b", "comprehensive" => "#166534", "substantive" => "#854d0e", "superficial" => "#991b1b" }
  _rec_bg = { "high_match" => "#dcfce7", "moderate_match" => "#fef9c3", "low_match" => "#fee2e2", "comprehensive" => "#dcfce7", "substantive" => "#fef9c3", "superficial" => "#fee2e2" }
%>

<%# Pipeline columns %>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; align-items: start;">
  <% [
       ["cv_review",             "CV Review",             "badge-pending",       "#f59e0b"],
       ["preliminary_interview", "Preliminary Interview", "badge-transcribing",  "#3b82f6"],
       ["client_interview",      "Shortlisted",           "badge-completed",     "#22c55e"],
       ["final_interview",       "Final Interview",       "badge-analyzing",     "#8b5cf6"]
     ].each do |stage, label, badge_class, border_color| %>
    <% lane = Array(grouped[stage]) %>
    <div>
      <%# Column header %>
      <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; padding: 0 0.25rem;">
        <span class="badge <%= badge_class %>" style="font-size: 0.8rem;"><%= label %></span>
        <% if lane.size > 0 %>
          <span style="font-size: 0.75rem; font-weight: 700; color: #555; background: #e5e5e5;
                       border-radius: 99px; padding: 0.1rem 0.5rem;"><%= lane.size %></span>
        <% end %>
      </div>

      <% if lane.empty? %>
        <div style="border: 2px dashed #e5e5e5; border-radius: 8px; padding: 2rem 1rem;
                    text-align: center; background: #fafafa;">
          <p style="color: #ccc; font-size: 0.85rem; margin: 0;">No candidates</p>
        </div>
      <% else %>
        <% lane.each do |c| %>
          <div style="background: #fff; border: 1px solid #e5e5e5; border-radius: 8px;
                      padding: 1rem; margin-bottom: 0.75rem;
                      border-left: 3px solid <%= border_color %>;">
            <%# Name %>
            <div style="font-weight: 600; font-size: 0.95rem; margin-bottom: 0.2rem;">
              <%= link_to c.name, candidate_path(c), style: "color: #1a1a1a; text-decoration: none;" %>
            </div>

            <%# Role %>
            <div style="font-size: 0.8rem; color: #888; margin-bottom: 0.6rem;">
              <%= c.job_role&.title %>
            </div>

            <%# Scores %>
            <div style="display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
              <% cv_fit = c.cv_fit_score %>
              <% if cv_fit.present? %>
                <% cv_tc, cv_bg = cv_fit >= 7.5 ? ["#166534", "#dcfce7"] : cv_fit >= 5.0 ? ["#854d0e", "#fef9c3"] : ["#991b1b", "#fee2e2"] %>
                <%= link_to cv_analysis_path(c.cv_analysis),
                      style: "font-size: 0.78rem; background: #{cv_bg}; border-radius: 4px;
                             padding: 0.2rem 0.5rem; color: #{cv_tc}; text-decoration: none; font-weight: 600;" do %>
                  CV <%= cv_fit %>
                <% end %>
              <% end %>
              <% if c.episode_score %>
                <% ep_tc, ep_bg = c.episode_score >= 7.5 ? ["#166534", "#dcfce7"] : c.episode_score >= 5.0 ? ["#854d0e", "#fef9c3"] : ["#991b1b", "#fee2e2"] %>
                <%= link_to video_analysis_path(c.video_analysis),
                      style: "font-size: 0.78rem; background: #{ep_bg}; border-radius: 4px;
                             padding: 0.2rem 0.5rem; color: #{ep_tc}; text-decoration: none; font-weight: 600;" do %>
                  Ep <%= c.episode_score %>
                <% end %>
              <% end %>
            </div>

            <%# Footer actions %>
            <div style="display: flex; justify-content: flex-end; gap: 0.4rem;">
              <%= link_to "View →", candidate_path(c),
                    class: "btn", style: "padding: 0.3rem 0.65rem; font-size: 0.78rem;" %>
              <%= button_to "✕", candidate_path(c),
                    method: :delete,
                    data: { turbo_confirm: "Permanently delete #{c.name}? This will also remove their CV analysis and video interview recording. This cannot be undone." },
                    class: "btn",
                    style: "padding: 0.3rem 0.55rem; font-size: 0.78rem; background: #dc2626;" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>

<%# Hired + Offer Declined + Not Invited + Rejected + No Shows — collapsed by default %>
<% hired              = Array(grouped["hired"]) %>
<% offer_declined     = Array(grouped["offer_declined"]) %>
<% not_selected_all   = Array(grouped["not_selected"]) %>
<% no_show_prelim     = not_selected_all.select(&:preliminary_interview_no_show?) %>
<% not_selected       = not_selected_all.reject(&:preliminary_interview_no_show?) %>
<% no_show_final      = @candidates.select(&:final_interview_no_show?) %>
<% not_invited        = Array(grouped["not_invited"]) %>
<% rejected           = Array(grouped["rejected"]) %>
<% terminal = hired + offer_declined + no_show_prelim + no_show_final + not_selected + not_invited + rejected %>
<% if terminal.any? %>
  <details style="margin-top: 1.75rem;">
    <summary style="font-size: 0.85rem; color: #999; cursor: pointer; user-select: none;
                    list-style: none; display: inline-flex; align-items: center; gap: 0.4rem;">
      <span>▶</span>
      <span>
        <% parts = [] %>
        <% parts << "Hired (#{hired.size})" if hired.any? %>
        <% parts << "Offer Declined (#{offer_declined.size})" if offer_declined.any? %>
        <% parts << "No Show - Prelim (#{no_show_prelim.size})" if no_show_prelim.any? %>
        <% parts << "No Show - Final (#{no_show_final.size})" if no_show_final.any? %>
        <% parts << "Not Selected (#{not_selected.size})" if not_selected.any? %>
        <% parts << "Not Invited (#{not_invited.size})" if not_invited.any? %>
        <% parts << "Rejected (#{rejected.size})" if rejected.any? %>
        <%= parts.join(" · ") %>
      </span>
    </summary>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
                gap: 0.75rem; margin-top: 0.75rem;">
      <% terminal.each do |c| %>
        <% if c.preliminary_interview_no_show? %>
          <% border = "#f59e0b"; label = "No Show (Prelim)"; color = "#92400e" %>
        <% elsif c.final_interview_no_show? %>
          <% border = "#f59e0b"; label = "No Show (Final)"; color = "#92400e" %>
        <% else %>
          <% border = { "hired" => "#16a34a", "offer_declined" => "#f59e0b", "not_selected" => "#6b7280", "not_invited" => "#f59e0b", "rejected" => "#dc2626" }[c.pipeline_stage] %>
          <% label  = { "hired" => "Hired", "offer_declined" => "Offer Declined", "not_selected" => "Not Selected", "not_invited" => "Not Invited", "rejected" => "Rejected" }[c.pipeline_stage] %>
          <% color  = { "hired" => "#166534", "offer_declined" => "#92400e", "not_selected" => "#374151", "not_invited" => "#92400e", "rejected" => "#991b1b" }[c.pipeline_stage] %>
        <% end %>
        <div style="background: #fff; border: 1px solid #e5e5e5; border-radius: 8px;
                    padding: 1rem; border-left: 3px solid <%= border %>; opacity: 0.7;">
          <div style="font-weight: 600; font-size: 0.9rem; margin-bottom: 0.2rem;">
            <%= link_to c.name, candidate_path(c), style: "color: #1a1a1a; text-decoration: none;" %>
          </div>
          <% if c.job_role %>
            <div style="font-size: 0.78rem; color: #aaa; margin-bottom: 0.4rem;"><%= c.job_role.title %></div>
          <% end %>
          <div style="display: flex; gap: 0.4rem; align-items: center; flex-wrap: wrap;">
            <span style="font-size: 0.72rem; color: <%= color %>; font-weight: 600;"><%= label %></span>
            <% t_cv_fit = c.cv_fit_score %>
            <% if t_cv_fit.present? %>
              <% t_cv_tc, t_cv_bg = t_cv_fit >= 7.5 ? ["#166534", "#dcfce7"] : t_cv_fit >= 5.0 ? ["#854d0e", "#fef9c3"] : ["#991b1b", "#fee2e2"] %>
              <%= link_to cv_analysis_path(c.cv_analysis),
                    style: "font-size: 0.72rem; background: #{t_cv_bg}; border-radius: 4px;
                           padding: 0.15rem 0.45rem; color: #{t_cv_tc}; text-decoration: none; font-weight: 600;" do %>
                CV <%= t_cv_fit %>
              <% end %>
            <% end %>
            <% if c.episode_score %>
              <% t_ep_tc, t_ep_bg = c.episode_score >= 7.5 ? ["#166534", "#dcfce7"] : c.episode_score >= 5.0 ? ["#854d0e", "#fef9c3"] : ["#991b1b", "#fee2e2"] %>
              <%= link_to video_analysis_path(c.video_analysis),
                    style: "font-size: 0.72rem; background: #{t_ep_bg}; border-radius: 4px;
                           padding: 0.15rem 0.45rem; color: #{t_ep_tc}; text-decoration: none; font-weight: 600;" do %>
                Ep <%= c.episode_score %>
              <% end %>
            <% end %>
          </div>
          <%# ── Rejection feedback email (not_invited / not_selected only) ── %>
          <% if %w[not_invited not_selected].include?(c.pipeline_stage) && c.email.present? %>
            <div style="margin-top: 0.65rem; padding-top: 0.55rem; border-top: 1px solid #f0f0f0;">
              <% if c.rejection_email_sent_at %>
                <span style="font-size: 0.7rem; color: #16a34a; font-weight: 600;">
                  ✓ Feedback sent <%= c.rejection_email_sent_at.strftime("%b %-d") %>
                </span>
              <% else %>
                <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
                  <%= link_to "✉ Send feedback",
                        send_rejection_email_candidate_path(c),
                        target: "_blank", rel: "noopener",
                        style: "font-size: 0.7rem; color: #0369a1; text-decoration: none; font-weight: 500;" %>
                  <%= button_to "Mark sent",
                        mark_rejection_sent_candidate_path(c),
                        method: :post,
                        style: "font-size: 0.7rem; background: none; border: none; padding: 0;
                                cursor: pointer; color: #aaa; text-decoration: underline;" %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
<% end %>

<% if @candidates.none? %>
  <div class="card" style="margin-top: 1rem;">
    <p class="empty" style="padding: 1rem 0;">
      No candidates yet. <%= link_to "Upload a CV", cv_analyses_path %> to start the pipeline.
    </p>
  </div>
<% end %>
