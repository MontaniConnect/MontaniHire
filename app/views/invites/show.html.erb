<div style="max-width: 480px; margin: 4rem auto;">
  <div class="card" style="text-align: center; padding: 2.5rem 2rem;">
    <h1 style="font-size: 1.4rem; margin-bottom: 0.4rem;">You've been invited</h1>
    <p style="color: #666; font-size: 0.9rem; margin-bottom: 2rem;">
      <%= @invite.invited_by.name.presence || @invite.invited_by.email %> has invited you to join
      <strong><%= @invite.organization.name %></strong> as a
      <strong><%= @invite.role.titleize %></strong>.
    </p>

    <p style="font-size: 0.85rem; color: #888; margin-bottom: 1.5rem;">
      This invite was sent to <strong><%= @invite.email %></strong>.
      Sign in with that Google account to accept.
    </p>

    <%= form_with url: accept_join_path(@invite.token), method: :post do %>
      <% if current_user %>
        <% if current_user.email.downcase == @invite.email.downcase %>
          <button type="submit" class="btn" style="width: 100%; font-size: 1rem; padding: 0.75rem;">
            Accept invite &rarr;
          </button>
        <% else %>
          <p style="color: #b91c1c; font-size: 0.88rem; margin-bottom: 1rem;">
            You're signed in as <strong><%= current_user.email %></strong> but this invite is for <strong><%= @invite.email %></strong>.
            Sign out and sign in with the correct account.
          </p>
        <% end %>
      <% else %>
        <%= link_to auth_google_login_path, class: "btn", style: "display: block; text-align: center; padding: 0.75rem; font-size: 1rem; text-decoration: none;" do %>
          Sign in with Google to accept
        <% end %>
      <% end %>
    <% end %>

    <p style="margin-top: 1.5rem; font-size: 0.78rem; color: #aaa;">
      Invite expires <%= time_ago_in_words(@invite.expires_at) %> from now.
    </p>
  </div>
</div>
