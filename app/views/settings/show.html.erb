<h1>Settings</h1>

<% if current_user.owner? %>
  <div class="card">
    <h2>Members</h2>
    <p style="font-size: 0.85rem; color: #666; margin-bottom: 1.5rem;">
      Manage who has access to your organisation's pipeline.
    </p>

    <%# Current members %>
    <% if @members.any? %>
      <div style="border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem;">
        <% @members.each_with_index do |member, idx| %>
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem;
                      <%= idx > 0 ? 'border-top: 1px solid #f0f0f0;' : '' %>">
            <div>
              <div style="font-weight: 500; font-size: 0.9rem;"><%= member.name.presence || member.email %></div>
              <div style="font-size: 0.78rem; color: #888;"><%= member.email %></div>
            </div>
            <span style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
                         color: <%= member.owner? ? '#166534' : '#555' %>;
                         background: <%= member.owner? ? '#dcfce7' : '#f0f0f0' %>;
                         border-radius: 4px; padding: 0.2rem 0.55rem;">
              <%= member.role.titleize %>
            </span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Pending invites %>
    <% if @pending_invites.any? %>
      <h3 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.75rem; color: #444;">Pending Invites</h3>
      <div style="border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem;">
        <% @pending_invites.each_with_index do |invite, idx| %>
          <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 0.75rem 1rem;
                      <%= idx > 0 ? 'border-top: 1px solid #f0f0f0;' : '' %>; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 0.9rem; font-weight: 500;"><%= invite.email %></div>
              <div style="font-size: 0.75rem; color: #888;">
                <%= invite.role.titleize %> &middot; expires <%= time_ago_in_words(invite.expires_at) %> from now
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem; flex-shrink: 0;">
              <input type="text" value="<%= join_url(invite.token) %>" readonly
                     style="font-size: 0.75rem; padding: 0.3rem 0.5rem; border: 1px solid #ddd; border-radius: 5px;
                            width: 260px; color: #555; background: #fafafa; font-family: monospace;"
                     onclick="this.select(); document.execCommand('copy'); this.blur(); this.nextElementSibling.textContent='Copied!';"
                     title="Click to copy">
              <span style="font-size: 0.72rem; color: #888; min-width: 40px;"></span>
              <%= button_to invite_path(invite), method: :delete,
                    style: "font-size: 0.75rem; color: #b91c1c; background: none; border: none; cursor: pointer; padding: 0;",
                    data: { confirm: "Revoke this invite?" } do %>
                Revoke
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Invite form %>
    <h3 style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.75rem; color: #444;">Invite someone</h3>
    <%= form_with url: invites_path, method: :post, html: { style: "display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: flex-end;" } do |f| %>
      <div class="form-group" style="margin: 0; flex: 1; min-width: 200px;">
        <%= f.label :email, "Email address", style: "font-size: 0.82rem;" %>
        <%= f.email_field :email, placeholder: "colleague@example.com",
              style: "padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; width: 100%;",
              name: "invite[email]" %>
      </div>
      <div class="form-group" style="margin: 0;">
        <%= f.label :role, "Role", style: "font-size: 0.82rem;" %>
        <select name="invite[role]" style="padding: 0.5rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; background: #fff;">
          <option value="member">Member — can upload and manage candidates</option>
          <option value="viewer">Viewer — read-only access</option>
        </select>
      </div>
      <button type="submit" class="btn" style="padding: 0.5rem 1rem; white-space: nowrap;">Send invite link</button>
    <% end %>
  </div>
<% end %>

<%# Upcoming bookings %>
<% if @upcoming_bookings.any? %>
  <div class="card">
    <h2>Upcoming Interviews</h2>
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr>
            <th>Candidate</th>
            <th>Date & Time</th>
            <th>Duration</th>
            <th>Calendar</th>
          </tr>
        </thead>
        <tbody>
          <% @upcoming_bookings.each do |b| %>
            <% tz = ActiveSupport::TimeZone[current_user.availability["timezone"]] || Time.zone %>
            <tr>
              <td style="font-weight: 500;">
                <%= link_to b.candidate.name, candidate_path(b.candidate),
                      style: "color: #1a1a1a; text-decoration: none;" %>
              </td>
              <td><%= b.starts_at.in_time_zone(tz).strftime("%A, %b %-d · %-I:%M %p %Z") %></td>
              <td><%= ((b.ends_at - b.starts_at) / 60).to_i %> min</td>
              <td>
                <% if b.google_event_id.present? %>
                  <span style="font-size: 0.78rem; color: #166534; background: #dcfce7; border-radius: 4px; padding: 0.15rem 0.5rem; font-weight: 600;">✓ Synced</span>
                <% else %>
                  <span style="font-size: 0.78rem; color: #aaa;">—</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<div class="card">
  <h2>Interview Availability</h2>
  <p style="font-size: 0.85rem; color: #666; margin-bottom: 1.5rem;">
    Set the days and hours candidates can book interview slots. All times are in the selected timezone.
  </p>

  <%= form_with url: update_availability_settings_path, method: :patch do |f| %>

    <%# Slot duration + timezone %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
      <div class="form-group" style="margin: 0;">
        <label>Slot Duration</label>
        <select name="slot_duration" style="width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; background: #fff;">
          <% [15, 30, 45, 60].each do |m| %>
            <option value="<%= m %>" <%= "selected" if @availability["slot_duration"] == m %>><%= m %> minutes</option>
          <% end %>
        </select>
      </div>
      <div class="form-group" style="margin: 0;">
        <label>Timezone</label>
        <select name="timezone" style="width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; background: #fff;">
          <% [
               ["Philippine Time (PHT)",       "Asia/Manila"],
               ["Eastern Time (US & Canada)",  "Eastern Time (US & Canada)"],
               ["Central Time (US & Canada)",  "Central Time (US & Canada)"],
               ["Mountain Time (US & Canada)", "Mountain Time (US & Canada)"],
               ["Pacific Time (US & Canada)",  "Pacific Time (US & Canada)"]
             ].each do |label, val| %>
            <option value="<%= val %>" <%= "selected" if (@availability["timezone"] || "Asia/Manila") == val %>><%= label %></option>
          <% end %>
        </select>
      </div>
    </div>

    <%# Day rows %>
    <% day_labels = { "monday" => "Monday", "tuesday" => "Tuesday", "wednesday" => "Wednesday",
                      "thursday" => "Thursday", "friday" => "Friday",
                      "saturday" => "Saturday", "sunday" => "Sunday" } %>
    <div style="border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; margin-bottom: 1.5rem;">
      <% day_labels.each_with_index do |(day, label), idx| %>
        <% cfg = @availability.dig("days", day) || {} %>
        <div style="display: grid; grid-template-columns: 160px 1fr; align-items: center; gap: 1rem;
                    padding: 0.75rem 1rem; <%= idx > 0 ? 'border-top: 1px solid #f0f0f0;' : '' %>
                    background: <%= cfg['enabled'] ? '#fff' : '#fafafa' %>;"
             id="day-row-<%= day %>">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-weight: 500; font-size: 0.9rem; margin: 0;">
            <input type="checkbox" name="days[<%= day %>][enabled]" value="1"
                   <%= "checked" if cfg["enabled"] %>
                   onchange="toggleDay('<%= day %>', this.checked)"
                   style="width: 15px; height: 15px;">
            <%= label %>
          </label>
          <div id="day-times-<%= day %>" style="display: flex; align-items: center; gap: 0.5rem; <%= cfg['enabled'] ? '' : 'opacity: 0.35; pointer-events: none;' %>">
            <input type="time" name="days[<%= day %>][start]" value="<%= cfg['start'] || '09:00' %>"
                   style="padding: 0.35rem 0.5rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.88rem;">
            <span style="color: #aaa; font-size: 0.85rem;">to</span>
            <input type="time" name="days[<%= day %>][end]" value="<%= cfg['end'] || '17:00' %>"
                   style="padding: 0.35rem 0.5rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.88rem;">
          </div>
        </div>
      <% end %>
    </div>

    <button type="submit" class="btn">Save Availability</button>
  <% end %>
</div>

<script>
  function toggleDay(day, enabled) {
    const times = document.getElementById("day-times-" + day)
    const row   = document.getElementById("day-row-" + day)
    times.style.opacity = enabled ? "1" : "0.35"
    times.style.pointerEvents = enabled ? "" : "none"
    row.style.background = enabled ? "#fff" : "#fafafa"
  }
</script>
