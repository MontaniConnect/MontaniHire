<%= form_with model: @shortlist do |f| %>
  <% if @shortlist.errors.any? %>
    <div class="error-box" style="margin-bottom: 1rem;">
      <% @shortlist.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "Shortlist name" %>
    <%= f.text_field :title, placeholder: "e.g. Senior Rails Developer – Round 2" %>
  </div>

  <div class="form-group">
    <%= f.label :client_email, "Client email" %>
    <%= f.text_field :client_email, placeholder: "client@company.com", type: "email" %>
    <span style="font-size: 0.8rem; color: #888; margin-top: 0.25rem; display: block;">
      The client must enter this address to unlock the shared link.
    </span>
  </div>

  <div class="form-group">
    <%= f.label :message, "Message to client (optional)" %>
    <%= f.text_area :message, rows: 3,
          placeholder: "Hi, here are the shortlisted candidates for your review…" %>
  </div>

  <% if @candidate %>
    <%= hidden_field_tag :type,         @candidate.class.name %>
    <%= hidden_field_tag :candidate_id, @candidate.id %>
  <% end %>

  <%= f.submit "Save shortlist", class: "btn" %>
<% end %>
