<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Candidate Shortlist</title>
    <%= csrf_meta_tags %>
    <%= javascript_importmap_tags %>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f5f5f5;
        color: #1a1a1a;
        line-height: 1.5;
        min-height: 100vh;
      }

      .shared-header {
        background: #1a1a1a;
        padding: 0 2rem;
        height: 56px;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .shared-header .agency-name { color: #fff; font-weight: 700; font-size: 1.1rem; letter-spacing: -0.02em; }
      .shared-header .sub { color: #888; font-size: 0.85rem; font-weight: 400; margin-left: 1rem; }
      .shared-header .cobranding-divider { color: #444; font-size: 0.9rem; margin: 0 0.25rem; }
      .shared-header .client-logo { height: 28px; width: auto; border-radius: 4px; object-fit: contain; background: #fff; padding: 2px 6px; }
      .shared-header .client-name { color: #ccc; font-size: 0.88rem; font-weight: 500; }

      .container { max-width: 900px; margin: 2rem auto; padding: 0 1.5rem; }

      .card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1.25rem;
      }

      h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
      h2 { font-size: 1.05rem; font-weight: 600; margin-bottom: 0.65rem; color: #333; }

      .form-group { margin-bottom: 1rem; }
      label { display: block; font-size: 0.85rem; font-weight: 500; color: #555; margin-bottom: 0.35rem; }

      input[type="text"], input[type="email"] {
        width: 100%; padding: 0.6rem 0.75rem;
        border: 1px solid #ddd; border-radius: 6px;
        font-size: 0.95rem; outline: none;
        transition: border-color 0.15s;
      }
      input[type="text"]:focus, input[type="email"]:focus { border-color: #555; }

      textarea {
        width: 100%; padding: 0.6rem 0.75rem;
        border: 1px solid #ddd; border-radius: 6px;
        font-size: 0.95rem; outline: none; resize: vertical;
        transition: border-color 0.15s; font-family: inherit;
      }
      textarea:focus { border-color: #555; }

      select {
        width: 100%; padding: 0.6rem 0.75rem;
        border: 1px solid #ddd; border-radius: 6px;
        font-size: 0.95rem; outline: none; background: #fff;
        transition: border-color 0.15s;
      }
      select:focus { border-color: #555; }

      .btn {
        display: inline-block; padding: 0.6rem 1.25rem;
        background: #1a1a1a; color: #fff;
        border: none; border-radius: 6px;
        font-size: 0.9rem; font-weight: 500;
        cursor: pointer; text-decoration: none;
        transition: background 0.15s;
      }
      .btn:hover { background: #333; }

      .badge {
        display: inline-block; padding: 0.2rem 0.6rem;
        border-radius: 99px; font-size: 0.75rem; font-weight: 600;
      }
      .badge-pending  { background: #fff3cd; color: #856404; }
      .badge-approved { background: #d4edda; color: #155724; }
      .badge-rejected { background: #f8d7da; color: #721c24; }
      .badge-score    { background: #e9ecef; color: #333; }
      .badge-cv       { background: #cfe2ff; color: #084298; }
      .badge-video    { background: #d1ecf1; color: #0c5460; }

      .alert {
        padding: 0.75rem 1rem; border-radius: 6px;
        font-size: 0.88rem; margin-bottom: 1rem;
      }
      .alert-notice { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
      .alert-alert  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

      .candidate-card {
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        margin-bottom: 1rem;
        overflow: hidden;
      }
      .candidate-card-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .candidate-card-body { padding: 1.25rem; }

      .score-circle {
        width: 52px; height: 52px; border-radius: 50%;
        background: conic-gradient(#1a1a1a var(--pct), #e5e5e5 0);
        display: flex; align-items: center; justify-content: center;
        position: relative; flex-shrink: 0;
      }
      .score-circle::before {
        content: ""; position: absolute; inset: 6px;
        background: #fff; border-radius: 50%;
      }
      .score-inner { position: relative; z-index: 1; font-size: 0.85rem; font-weight: 700; }

      .feedback-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
      .feedback-cols h3 { font-size: 0.78rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.4rem; }
      .feedback-cols ul { list-style: none; }
      .feedback-cols ul li { font-size: 0.88rem; padding: 0.2rem 0; border-bottom: 1px solid #f5f5f5; }
      .feedback-cols ul li::before { content: "• "; color: #bbb; }

      .feedback-form { border-top: 1px solid #f0f0f0; padding-top: 1rem; margin-top: 1rem; }
      .feedback-form label { font-size: 0.8rem; }

      .empty { color: #999; font-size: 0.9rem; text-align: center; padding: 2rem 0; }
    </style>
  </head>
  <body>
    <header class="shared-header">
      <span class="agency-name">MontaniHire</span>
      <% _client = defined?(@shortlist) && @shortlist&.client %>
      <% if _client %>
        <span class="cobranding-divider">×</span>
        <% if _client.logo_url.present? %>
          <img src="<%= _client.logo_url %>"
               alt="<%= _client.name %>"
               class="client-logo"
               onerror="this.style.display='none'">
        <% end %>
        <span class="client-name"><%= _client.name %></span>
      <% else %>
        <span class="sub">Candidate Shortlist</span>
      <% end %>
    </header>
    <div class="container">
      <%= yield %>
    </div>
  </body>
</html>
