<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Interview Invitation</title>
    <%= csrf_meta_tags %>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #F4F5F7; color: #1a1a1a; line-height: 1.6;
        min-height: 100vh; display: flex; align-items: flex-start; justify-content: center;
        padding: 2rem 1rem;
      }
      .card {
        background: #fff; border: 1px solid #e5e5e5; border-radius: 10px;
        padding: 2rem; width: 100%; max-width: 520px;
      }
      .brand { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #0E1B33; margin-bottom: 1.5rem; }
      h1 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.4rem; }
      .subtitle { font-size: 0.9rem; color: #555; margin-bottom: 1.75rem; line-height: 1.55; }
      .form-group { margin-bottom: 1.25rem; }
      label { display: block; font-size: 0.85rem; font-weight: 500; color: #333; margin-bottom: 0.35rem; }
      input[type="number"], input[type="text"] {
        width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #ddd; border-radius: 6px;
        font-size: 0.95rem; outline: none; transition: border-color 0.15s;
      }
      input[type="number"]:focus, input[type="text"]:focus { border-color: #1A7A85; }
      .checkbox-row {
        display: flex; align-items: flex-start; gap: 0.6rem;
        background: #fafafa; border: 1px solid #e5e5e5; border-radius: 8px;
        padding: 0.85rem 1rem; margin-bottom: 0.75rem;
      }
      .checkbox-row input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px; cursor: pointer; }
      .checkbox-row label { margin: 0; font-size: 0.9rem; font-weight: 400; color: #1a1a1a; cursor: pointer; }
      .php-prefix { display: flex; align-items: center; }
      .php-prefix span {
        padding: 0.6rem 0.75rem; background: #f5f5f5; border: 1px solid #ddd;
        border-right: none; border-radius: 6px 0 0 6px; font-size: 0.9rem; color: #666; white-space: nowrap;
      }
      .php-prefix input { border-radius: 0 6px 6px 0; }
      .btn {
        display: block; width: 100%; padding: 0.75rem; background: #0E1B33; color: #fff;
        border: none; border-radius: 6px; font-size: 0.95rem; font-weight: 600;
        cursor: pointer; text-align: center; margin-top: 1.5rem;
        transition: background 0.15s;
      }
      .btn:hover { background: #16264A; }
      .divider { border: none; border-top: 1px solid #f0f0f0; margin: 1.5rem 0; }
      .note { font-size: 0.8rem; color: #999; margin-top: 0.35rem; }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="brand">MontaniHire</div>
      <%= yield %>
    </div>
  </body>
</html>
