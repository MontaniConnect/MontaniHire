<h1>Video Interviews</h1>

<div style="font-size: 0.88rem; color: #888; margin-bottom: 1.25rem;">
  To upload an interview recording, open a candidate's profile and use the Upload Interview button there.
  <%= link_to "View candidates →", candidates_path, style: "color: #555; font-weight: 600;" %>
</div>

<% if @video_analyses.any? %>
  <% grouped = @video_analyses.group_by { |va| va.job_role&.title || "No Role" } %>
  <% latest_role = @video_analyses.select { |va| va.status == "completed" }.max_by(&:updated_at)&.job_role&.title || "No Role" %>
  <% grouped.each do |role_title, analyses| %>
    <details <%= "open" if role_title == latest_role %> style="margin-bottom: 0.75rem;">
      <summary style="list-style: none; cursor: pointer; user-select: none;">
        <div class="card" style="display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 1.25rem; margin: 0;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-size: 0.75rem; color: #aaa; font-weight: 700; transition: transform 0.15s;"
                  data-toggle-icon>▶</span>
            <span style="font-weight: 600; font-size: 0.95rem; color: #1a1a1a;"><%= role_title %></span>
          </div>
          <span style="font-size: 0.78rem; font-weight: 700; color: #555; background: #f0f0f0;
                       border-radius: 99px; padding: 0.15rem 0.6rem;">
            <%= analyses.size %> candidate<%= "s" if analyses.size != 1 %>
          </span>
        </div>
      </summary>

      <div class="card" style="padding: 0; overflow: hidden; margin-top: -0.5rem; border-top: none; border-radius: 0 0 8px 8px;">
        <div class="table-wrapper"><table class="data-table">
          <thead>
            <tr>
              <th>Candidate</th>
              <th>Episode Score</th>
              <th>Status</th>
              <th>Uploaded</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% analyses.each do |va| %>
              <tr style="cursor: pointer;" onclick="window.location='<%= video_analysis_path(va) %>'">
                <td style="font-weight: 500;"><%= va.display_name.titleize %></td>
                <td>
                  <% ep = va.episode_score %>
                  <% if ep.present? %>
                    <% tier = va.episode_tier %>
                    <% tier_color = { "Shortlist" => "#166534", "Borderline" => "#854d0e", "Archive" => "#991b1b" }[tier] %>
                    <% tier_bg    = { "Shortlist" => "#dcfce7", "Borderline" => "#fef9c3", "Archive" => "#fee2e2" }[tier] %>
                    <span style="font-weight: 700;"><%= ep %>/10</span>
                    <span style="font-size: 0.72rem; font-weight: 600; color: <%= tier_color %>; background: <%= tier_bg %>; border-radius: 4px; padding: 0.1rem 0.4rem; margin-left: 0.35rem;"><%= tier %></span>
                  <% else %>
                    <span style="color: #bbb;">—</span>
                  <% end %>
                </td>
                <td><span class="badge badge-<%= va.status %>"><%= va.status %></span></td>
                <td style="color: #999; font-size: 0.85rem;"><%= time_ago_in_words(va.created_at) %> ago</td>
                <td onclick="event.stopPropagation()">
                  <%= button_to "✕", video_analysis_path(va),
                        method: :delete,
                        data: { turbo_confirm: "Delete interview analysis for #{va.display_name.titleize}? The candidate record will be kept." },
                        style: "padding: 0.25rem 0.55rem; font-size: 0.78rem; background: #dc2626;
                                color: #fff; border: none; border-radius: 4px; cursor: pointer;" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table></div>
      </div>
    </details>
  <% end %>
<% else %>
  <div class="card">
    <p class="empty">No interview recordings yet. Upload one from a candidate's profile.</p>
  </div>
<% end %>
