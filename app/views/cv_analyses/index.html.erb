<h1>CV Analysis</h1>

<% if current_user.job_roles.none? %>
  <div class="card">
    <div class="error-box">
      No job roles yet. <%= link_to "Create a role first →", new_job_role_path, style: "color: #dc2626; font-weight: 600;" %>
    </div>
  </div>
<% else %>
  <div class="card" data-controller="bulk-upload">

    <%# ── Header with Google Drive connection status ── %>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
      <h2 style="margin: 0;">Add CV</h2>
      <% if current_user.google_connected? %>
        <div style="display: flex; align-items: center; gap: 0.6rem;">
          <span style="font-size: 0.78rem; color: #166534; background: #dcfce7; border-radius: 99px; padding: 0.2rem 0.65rem; font-weight: 600;">✓ Google Drive connected</span>
          <%= button_to "Disconnect", auth_google_disconnect_path, method: :delete,
                style: "font-size: 0.75rem; color: #888; background: none; border: none; cursor: pointer; text-decoration: underline; padding: 0;" %>
        </div>
      <% else %>
        <%= link_to auth_google_path,
              style: "font-size: 0.8rem; display: inline-flex; align-items: center; gap: 0.35rem;
                      padding: 0.3rem 0.75rem; border: 1px solid #ddd; border-radius: 6px;
                      color: #555; text-decoration: none; background: #fff; white-space: nowrap;" do %>
          <svg width="14" height="14" viewBox="0 0 48 48" style="flex-shrink:0"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
          Connect Google Drive
        <% end %>
      <% end %>
    </div>

    <%# ── Tab switcher ── %>
    <div style="display: flex; gap: 0; border-bottom: 2px solid #f0f0f0; margin-bottom: 1.25rem;">
      <button type="button" id="cv-tab-single"
              data-bulk-upload-target="tabSingle"
              data-action="click->bulk-upload#showSingle"
              style="padding: 0.5rem 1rem; font-size: 0.88rem; font-weight: 600; border: none; border-bottom: 2px solid #1a1a1a; margin-bottom: -2px; background: none; cursor: pointer; color: #1a1a1a;">
        Single upload
      </button>
      <button type="button" id="cv-tab-bulk"
              data-bulk-upload-target="tabBulk"
              data-action="click->bulk-upload#showBulk"
              style="padding: 0.5rem 1rem; font-size: 0.88rem; font-weight: 500; border: none; border-bottom: 2px solid transparent; margin-bottom: -2px; background: none; cursor: pointer; color: #888;">
        Bulk upload
      </button>
      <button type="button" id="cv-tab-drive"
              onclick="cvSwitchToDrive()"
              style="padding: 0.5rem 1rem; font-size: 0.88rem; font-weight: 500; border: none; border-bottom: 2px solid transparent; margin-bottom: -2px; background: none; cursor: pointer; color: #888;">
        From Google Drive
      </button>
    </div>

    <%# ── Single upload form ── %>
    <div data-bulk-upload-target="panelSingle" id="cv-panel-single">
      <%= form_with url: cv_analyses_path, multipart: true, data: { controller: "upload" } do |f| %>
        <div class="form-group">
          <label>Job Role</label>
          <%= select_tag "cv_analysis[job_role_id]",
                options_from_collection_for_select(current_user.job_roles.order(:title), :id, :title),
                prompt: "Select a role…",
                required: true %>
        </div>
        <div class="form-group">
          <label>Candidate Name</label>
          <input type="text"
                 name="cv_analysis[candidate_name]"
                 placeholder="e.g. Jane Smith"
                 required
                 data-upload-target="name">
        </div>
        <div class="form-group">
          <label class="drop-zone" data-upload-target="zone">
            <input type="file"
                   name="cv_analysis[cv]"
                   accept=".pdf,.docx,.txt"
                   required
                   style="display:none"
                   data-upload-target="input"
                   data-action="change->upload#preview">
            <div data-upload-target="prompt">
              <div style="font-size: 2rem; margin-bottom: 0.5rem;">📄</div>
              <div style="font-weight: 500;">Click to choose a CV file</div>
              <div style="font-size: 0.8rem; color: #999; margin-top: 0.25rem;">PDF, DOCX, or TXT</div>
            </div>
            <div data-upload-target="filename" style="display:none; font-weight: 500; color: #333;"></div>
          </label>
        </div>
        <%= f.submit "Analyse CV", class: "btn", data: { upload_target: "button" } %>
      <% end %>
    </div>

    <%# ── Bulk upload form ── %>
    <div data-bulk-upload-target="panelBulk" id="cv-panel-bulk" style="display: none;">
      <p style="font-size: 0.88rem; color: #666; margin-bottom: 1rem;">
        Select multiple CV files at once. Candidate names are taken from filenames — rename files before uploading if needed (e.g. <code>Jane Smith.pdf</code>).
      </p>
      <%= form_with url: bulk_create_cv_analyses_path, multipart: true do |f| %>
        <div class="form-group">
          <label>Job Role</label>
          <%= select_tag "job_role_id",
                options_from_collection_for_select(current_user.job_roles.order(:title), :id, :title),
                prompt: "Select a role…",
                required: true %>
        </div>
        <div class="form-group">
          <label class="drop-zone" style="min-height: 100px;">
            <input type="file"
                   name="cvs[]"
                   accept=".pdf,.docx,.txt"
                   multiple
                   required
                   style="display:none"
                   data-bulk-upload-target="input"
                   data-action="change->bulk-upload#preview">
            <div data-bulk-upload-target="prompt">
              <div style="font-size: 2rem; margin-bottom: 0.5rem;">📂</div>
              <div style="font-weight: 500;">Click to choose multiple CV files</div>
              <div style="font-size: 0.8rem; color: #999; margin-top: 0.25rem;">PDF, DOCX, or TXT — hold Cmd/Ctrl to select multiple</div>
            </div>
            <ul data-bulk-upload-target="fileList"
                style="display:none; list-style:none; margin:0; padding:0; text-align:left; width:100%;"></ul>
          </label>
        </div>
        <button type="submit" class="btn" data-bulk-upload-target="submitBtn">
          Upload & Analyse All
        </button>
      <% end %>
    </div>

    <%# ── Google Drive tab ── %>
    <div id="cv-panel-drive" style="display: none;"
         data-controller="drive-picker"
         data-drive-picker-access-token-value="<%= current_user.fresh_google_access_token.to_s %>"
         data-drive-picker-api-key-value="<%= ENV.fetch('GOOGLE_BROWSER_API_KEY', '') %>"
         data-drive-picker-mime-types-value="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain">
      <%= form_with url: cv_analyses_path, id: "cv-form-drive" do |f| %>
        <div class="form-group">
          <label>Job Role</label>
          <%= select_tag "cv_analysis[job_role_id]",
                options_from_collection_for_select(current_user.job_roles.order(:title), :id, :title),
                prompt: "Select a role…",
                required: true %>
        </div>
        <div class="form-group">
          <label>Candidate Name</label>
          <input type="text" name="cv_analysis[candidate_name]" placeholder="e.g. Jane Smith" required
                 data-drive-picker-target="candidateName">
        </div>
        <%= hidden_field_tag "cv_analysis[drive_file_id]",   nil, data: { "drive-picker-target": "fileIdInput" } %>
        <%= hidden_field_tag "cv_analysis[drive_file_name]", nil, data: { "drive-picker-target": "fileNameInput" } %>

        <% if current_user.google_connected? %>
          <div class="form-group">
            <label style="display: flex; align-items: center; justify-content: space-between;">
              <span>CV File</span>
              <span style="font-size: 0.72rem; color: #aaa; font-weight: 400;">Optional: paste a Drive folder link to open the picker inside that folder</span>
            </label>
            <input type="text"
                   data-drive-picker-target="folderInput"
                   placeholder="https://drive.google.com/drive/folders/… (optional)"
                   style="width: 100%; padding: 0.45rem 0.6rem; border: 1px solid #ddd; border-radius: 6px;
                          font-size: 0.82rem; color: #555; margin-bottom: 0.5rem; box-sizing: border-box;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <button type="button"
                      data-drive-picker-target="button"
                      data-action="click->drive-picker#open"
                      style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem;
                             border: 1px dashed #ccc; border-radius: 6px; background: #fafafa;
                             font-size: 0.88rem; color: #555; cursor: pointer; width: fit-content;">
                <svg width="16" height="16" viewBox="0 0 87.3 78" style="flex-shrink:0"><path d="M6.6 66.85l3.85 6.65c.8 1.4 1.95 2.5 3.3 3.3L38.6 30H0c0 1.55.4 3.1 1.2 4.5z" fill="#0066DA"/><path d="M43.65 25L29.9 0c-1.35.8-2.5 1.9-3.3 3.3L1.2 45.5A9.06 9.06 0 000 50h38.6z" fill="#00AC47"/><path d="M73.55 76.8c1.35-.8 2.5-1.9 3.3-3.3l1.6-2.75 7.65-13.25c.8-1.4 1.2-2.95 1.2-4.5H48.7l8.55 16.05z" fill="#EA4335"/><path d="M43.65 25L57.4 0H29.9z" fill="#00832D"/><path d="M87.3 50H48.7L43.65 25 57.4 0c1.35.8 2.5 1.9 3.3 3.3l26.4 45.7c.8 1.4 1.2 2.95 1.2 4.5z" fill="#2684FC"/><path d="M73.55 76.8L48.7 50H87.3c0 1.55-.4 3.1-1.2 4.5L79.45 68l-5.9 8.8z" fill="#FFBA00"/></svg>
                Choose from Google Drive
              </button>
              <span data-drive-picker-target="fileLabel"
                    style="display:none; font-size: 0.85rem; color: #555; font-weight: 500;"></span>
            </div>
          </div>
        <% else %>
          <div class="error-box" style="margin-bottom: 1rem;">
            Connect your Google account above to browse Drive files.
          </div>
        <% end %>

        <%= f.submit "Analyse CV", class: "btn",
              disabled: true,
              style: "opacity: 0.4; cursor: not-allowed;",
              data: { "drive-picker-target": "submitBtn" } %>
      <% end %>
    </div>
  </div>
<% end %>

<script>
  function cvSwitchToDrive() {
    ["single", "bulk", "drive"].forEach(function(t) {
      const panel = document.getElementById("cv-panel-" + t)
      if (panel) panel.style.display = t === "drive" ? "" : "none"
    })
    ;["cv-tab-single", "cv-tab-bulk", "cv-tab-drive"].forEach(function(id) {
      const btn = document.getElementById(id)
      if (!btn) return
      const active = id === "cv-tab-drive"
      btn.style.borderBottomColor = active ? "#1a1a1a" : "transparent"
      btn.style.color = active ? "#1a1a1a" : "#888"
      btn.style.fontWeight = active ? "600" : "500"
    })
  }

  <% if @cv_analysis&.drive_file_id.present? %>
  document.addEventListener("DOMContentLoaded", function() { cvSwitchToDrive() })
  <% end %>
</script>

<% if @cv_analyses.any? %>
  <% grouped = @cv_analyses.group_by { |ca| ca.job_role&.title || "No Role" } %>
  <% latest_role = @cv_analyses.select { |ca| ca.status == "completed" }.max_by(&:updated_at)&.job_role&.title || "No Role" %>
  <% grouped.each do |role_title, analyses| %>
    <details <%= "open" if role_title == latest_role %> style="margin-bottom: 0.75rem;">
      <summary style="list-style: none; cursor: pointer; user-select: none;">
        <div class="card" style="display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 1.25rem; margin: 0;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-size: 0.75rem; color: #aaa; font-weight: 700; transition: transform 0.15s;"
                  data-toggle-icon>▶</span>
            <span style="font-weight: 600; font-size: 0.95rem; color: #1a1a1a;"><%= role_title %></span>
          </div>
          <span style="font-size: 0.78rem; font-weight: 700; color: #555; background: #f0f0f0;
                       border-radius: 99px; padding: 0.15rem 0.6rem;">
            <%= analyses.size %> candidate<%= "s" if analyses.size != 1 %>
          </span>
        </div>
      </summary>

      <div class="card" style="padding: 0; overflow: hidden; margin-top: -0.5rem; border-top: none; border-radius: 0 0 8px 8px;">
        <div class="table-wrapper"><table class="data-table">
          <thead>
            <tr>
              <th>Candidate</th>
              <th>CV Fit Score</th>
              <th>Status</th>
              <th>Uploaded</th>
            </tr>
          </thead>
          <tbody>
            <% analyses.each do |ca| %>
              <tr style="cursor: pointer;" onclick="window.location='<%= cv_analysis_path(ca) %>'">
                <td style="font-weight: 500;"><%= ca.display_name.titleize %></td>
                <td>
                  <% cf = ca.cv_fit_score %>
                  <% if cf %>
                    <% tier = ca.cv_fit_tier %>
                    <% tier_color = { "Shortlist" => "#166534", "Borderline" => "#854d0e", "Archive" => "#991b1b" }[tier] %>
                    <% tier_bg    = { "Shortlist" => "#dcfce7", "Borderline" => "#fef9c3", "Archive" => "#fee2e2" }[tier] %>
                    <span style="font-weight: 700;"><%= cf %>/10</span>
                    <span style="font-size: 0.72rem; font-weight: 600; color: <%= tier_color %>; background: <%= tier_bg %>; border-radius: 4px; padding: 0.1rem 0.4rem; margin-left: 0.35rem;"><%= tier %></span>
                  <% else %>
                    <span style="color: #bbb;">—</span>
                  <% end %>
                </td>
                <td><span class="badge badge-<%= ca.status %>"><%= ca.status %></span></td>
                <td style="color: #999; font-size: 0.85rem;"><%= time_ago_in_words(ca.created_at) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table></div>
      </div>
    </details>
  <% end %>
<% else %>
  <div class="card">
    <p class="empty">No candidates yet. Upload a CV above.</p>
  </div>
<% end %>
