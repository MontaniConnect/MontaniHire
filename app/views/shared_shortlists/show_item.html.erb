<% status_labels = { "pending" => "Hold", "approved" => "Invite", "rejected" => "Decline" } %>
<% status_badge  = { "pending" => "badge-pending", "approved" => "badge-approved", "rejected" => "badge-rejected" } %>

<% if flash[:notice] %>
  <div class="alert alert-notice"><%= flash[:notice] %></div>
<% end %>

<%# Back link %>
<div style="margin-bottom: 1.25rem;">
  <%= link_to "← All candidates", shared_shortlist_path(@shortlist.token),
        style: "font-size: 0.88rem; color: #888; text-decoration: none;" %>
</div>

<%# Header — name, type badge, role, current decision %>
<div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem;">
  <div>
    <h1 style="margin: 0 0 0.35rem;"><%= @item.candidate_name %></h1>
    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;">
      <% @item.kind.split(" + ").each do |k| %>
        <span class="badge <%= k == "CV" ? "badge-cv" : "badge-video" %>"><%= k %></span>
      <% end %>
      <% if @item.job_role %>
        <span class="badge" style="background: #f0f0f0; color: #555; font-size: 0.72rem; padding: 0.15rem 0.5rem;">
          <%= @item.job_role.title %>
        </span>
      <% end %>
    </div>
  </div>
  <span class="badge <%= status_badge[@item.client_status] %>" style="font-size: 0.82rem; align-self: flex-start;">
    <%= status_labels[@item.client_status] %>
  </span>
</div>

<%# ── Compensation Package ── %>
<% if @item.candidate&.compensation_package.present? %>
  <div class="card" style="padding: 0.75rem 1.25rem; margin-bottom: 1rem;">
    <div style="font-size: 0.7rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.2rem;">Compensation Package</div>
    <div style="font-size: 0.95rem; font-weight: 600; color: #1a1a1a;"><%= @item.candidate.compensation_package %></div>
  </div>
<% end %>

<%# ── Summary ── %>
<% cv = @item.resolved_cv_analysis %>
<% if @item.summary.present? %>
  <div class="card">
    <h2 style="margin: 0 0 0.75rem;">Summary</h2>
    <p style="font-size: 0.93rem; color: #333; line-height: 1.75; margin: 0;"><%= @item.summary %></p>
  </div>
<% end %>

<%# ── Video interview ── %>
<% va = @item.resolved_video_analysis %>
<% _va_segs     = va&.transcript_segments || [] %>
<% _va_hi       = va&.highlight_indices   || [] %>
<% _inline_video = va&.video&.attached? && va.video.blob&.content_type.to_s.start_with?("video/") %>
<% if va %>
  <% if _inline_video %>
    <div class="card" style="padding: 0; overflow: hidden;">
      <video id="interview-video" controls preload="metadata"
             style="width: 100%; display: block; background: #000; max-height: 480px;">
        <source src="<%= rails_blob_url(va.video, disposition: 'inline') %>"
                type="<%= va.video.blob.content_type %>">
      </video>
    </div>
  <% elsif va.drive_video_file_id.present? %>
    <div class="card" style="padding: 0; overflow: hidden;">
      <div style="position: relative; width: 100%; padding-bottom: 56.25%; background: #000;">
        <iframe src="https://drive.google.com/file/d/<%= va.drive_video_file_id %>/preview"
                allow="autoplay"
                style="position: absolute; inset: 0; width: 100%; height: 100%; border: none;">
        </iframe>
      </div>
    </div>
  <% end %>
<% end %>

<%# ── Key Moments ── %>
<% _drive_video_id = va&.drive_video_file_id.presence %>
<% _has_video = _inline_video || _drive_video_id.present? %>
<% if _va_hi.any? && _va_segs.any? %>
  <div class="card">
    <h2 style="margin: 0 0 0.15rem;">Key Moments</h2>
    <p style="font-size: 0.78rem; color: #aaa; margin: 0 0 0.85rem;">
      Excerpts from the interview worth reviewing.
      <% if _has_video %>Click a moment to jump to that point in the recording.<% end %>
    </p>
    <div style="display: flex; flex-direction: column; gap: 0.5rem;">
      <% _va_hi.each do |idx| %>
        <% seg = _va_segs[idx] %>
        <% next unless seg %>
        <% start_s = seg["start"].to_f %>
        <% ts_label = format("%d:%02d", (start_s / 60).to_i, (start_s % 60).to_i) %>
        <div style="display: flex; gap: 0.75rem; align-items: flex-start;
                    padding: 0.5rem 0.6rem; border-radius: 6px; border: 1px solid #f0f0f0;
                    cursor: <%= _has_video ? "pointer" : "default" %>; transition: background 0.15s;"
             onclick="jumpTo(<%= start_s.round(1) %>, <%= idx %>)"
             onmouseover="this.style.background='#fafafa'"
             onmouseout="this.style.background=''">
          <span style="font-size: 0.72rem; font-weight: 700; color: #fff; background: #1a1a1a;
                       border-radius: 4px; padding: 0.2rem 0.5rem; white-space: nowrap;
                       flex-shrink: 0; margin-top: 0.15rem; font-variant-numeric: tabular-nums;">
            <%= ts_label %>
          </span>
          <span style="font-size: 0.88rem; color: #333; line-height: 1.55;">
            "<%= seg["text"].truncate(240) %>"
          </span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>


<%# ── Feedback form ── %>
<div class="card">
  <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.85rem;">
    <h2 style="margin: 0;">Your decision</h2>
    <% if cv&.cv&.attached? || cv&.drive_file_id.present? %>
      <%= link_to "↓ Download CV", shared_shortlist_cv_path(@shortlist.token, @item),
            class: "btn", style: "padding: 0.35rem 0.85rem; font-size: 0.82rem; flex-shrink: 0; background: #0369a1;" %>
    <% end %>
  </div>
  <%= form_with url: shared_shortlist_feedback_path(@shortlist.token, @item),
                method: :patch, style: "display: flex; flex-direction: column; gap: 0.75rem;" do |f| %>
    <%
      decision_colors = {
        "pending"  => { bg: "#fef3c7", color: "#92400e", border: "#fcd34d", hover_bg: "#fde68a", active_bg: "#fbbf24" },
        "approved" => { bg: "#d1fae5", color: "#065f46", border: "#6ee7b7", hover_bg: "#a7f3d0", active_bg: "#34d399" },
        "rejected" => { bg: "#fee2e2", color: "#991b1b", border: "#fca5a5", hover_bg: "#fecaca", active_bg: "#f87171" }
      }
    %>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
      <% [["pending", "Hold"], ["approved", "Invite"], ["rejected", "Decline"]].each do |val, label| %>
        <% c = decision_colors[val] %>
        <% selected = @item.client_status == val %>
        <label style="flex: 1; min-width: 90px; cursor: pointer;">
          <input type="radio" name="client_status" value="<%= val %>"
                 <%= "checked" if selected %> style="display: none;"
                 onchange="this.closest('form').requestSubmit();">
          <div data-decision="<%= val %>"
               style="padding: 0.55rem 0.75rem; border: 2px solid <%= selected ? c[:border] : '#ddd' %>; border-radius: 6px; font-size: 0.88rem; font-weight: 600; text-align: center; transition: background 0.15s, border-color 0.15s;
                      <%= selected ? "background: #{c[:bg]}; color: #{c[:color]};" : "color: #555;" %>"
               onmouseover="if(!this.dataset.selected) { this.style.background='<%= c[:hover_bg] %>'; this.style.borderColor='<%= c[:border] %>'; this.style.color='<%= c[:color] %>'; }"
               onmouseout="if(!this.dataset.selected) { this.style.background=''; this.style.borderColor='#ddd'; this.style.color='#555'; }"
               onmousedown="if(!this.dataset.selected) { this.style.background='<%= c[:active_bg] %>'; }"
               onmouseup="if(!this.dataset.selected) { this.style.background='<%= c[:hover_bg] %>'; }"
               <%= "data-selected=true" if selected %>>
            <%= label %>
          </div>
        </label>
      <% end %>
    </div>
    <div>
      <label style="font-size: 0.8rem; font-weight: 500; color: #555; display: block; margin-bottom: 0.5rem;">Rating</label>
      <div style="display: flex; gap: 0.25rem; flex-direction: row-reverse; justify-content: flex-end;">
        <% (1..5).reverse_each do |i| %>
          <label style="cursor: pointer; font-size: 1.6rem; color: #d1d5db; line-height: 1;"
                 onmouseenter="highlightStars(this, <%= i %>)"
                 onmouseleave="resetStars(this.closest('div'))">
            <input type="radio" name="client_rating" value="<%= i %>"
                   <%= "checked" if @item.client_rating == i %>
                   style="display: none;"
                   onchange="resetStars(this.closest('div'))">
            ★
          </label>
        <% end %>
      </div>
    </div>
    <div>
      <label style="font-size: 0.8rem; font-weight: 500; color: #555; display: block; margin-bottom: 0.3rem;">Notes</label>
      <textarea name="client_comment" rows="3"
                placeholder="Add a note about this candidate…"
                style="width: 100%; padding: 0.6rem 0.75rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.9rem; font-family: inherit; resize: vertical;"><%= @item.client_comment %></textarea>
    </div>
    <%= f.submit "Save", class: "btn", style: "align-self: flex-start; padding: 0.5rem 1.25rem;" %>
  <% end %>
</div>

<%# ── No Show ── %>
<% if @item.client_status == "approved" && @item.candidate %>
  <% no_show = @item.candidate.final_interview_no_show %>
  <div class="card" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
    <div>
      <div style="font-weight: 600; font-size: 0.92rem; margin-bottom: 0.2rem;">Final Interview Attendance</div>
      <div style="font-size: 0.82rem; color: #888;">
        <%= no_show ? "Candidate did not attend the final interview." : "Candidate is expected to attend." %>
      </div>
    </div>
    <%= button_to no_show ? "↩ Clear No Show" : "⚠ Mark as No Show",
          shared_shortlist_no_show_path(@shortlist.token, @item),
          method: :patch,
          style: "padding: 0.45rem 1rem; font-size: 0.85rem; font-weight: 600; border: none; border-radius: 6px; cursor: pointer;
                  background: #{no_show ? '#6b7280' : '#f59e0b'}; color: #fff;" %>
  </div>
<% end %>

<script>
  var DRIVE_VIDEO_ID = "<%= _drive_video_id %>";

  function jumpTo(seconds, segIdx) {
    var video = document.getElementById('interview-video');
    if (video) {
      video.currentTime = seconds;
      video.play();
      video.scrollIntoView({ behavior: 'smooth', block: 'start' });
    } else if (DRIVE_VIDEO_ID) {
      var iframe = document.querySelector('iframe[src*="drive.google.com"]');
      if (iframe) {
        iframe.scrollIntoView({ behavior: 'smooth', block: 'start' });
        var mins = Math.floor(seconds / 60);
        var secs = Math.floor(seconds % 60);
        var label = mins + ':' + (secs < 10 ? '0' : '') + secs;
        var tip = document.getElementById('drive-seek-tip');
        if (!tip) {
          tip = document.createElement('div');
          tip.id = 'drive-seek-tip';
          tip.style.cssText = 'position:absolute;top:8px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.75);color:#fff;font-size:0.82rem;font-weight:600;padding:0.3rem 0.75rem;border-radius:99px;pointer-events:none;z-index:10;white-space:nowrap;';
          iframe.parentElement.style.position = 'relative';
          iframe.parentElement.appendChild(tip);
        }
        tip.textContent = 'Seek to ' + label;
        tip.style.opacity = '1';
        clearTimeout(tip._hide);
        tip._hide = setTimeout(function() { tip.style.opacity = '0'; }, 3000);
      }
    }
    var seg = document.getElementById('seg-' + segIdx);
    if (!seg) return;
    var container = document.getElementById('transcript-segments');
    if (container) {
      container.scrollTop = seg.offsetTop - container.offsetTop - 40;
    } else {
      seg.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    seg.style.transition = 'background 0.2s';
    var orig = seg.dataset.origBg || seg.style.background;
    seg.dataset.origBg = orig;
    seg.style.background = '#fef08a';
    setTimeout(function() { seg.style.background = orig; seg.style.transition = ''; }, 1800);
  }

  function highlightStars(hoveredLabel, upTo) {
    const container = hoveredLabel.closest("div")
    const labels    = Array.from(container.querySelectorAll("label")).reverse()
    labels.forEach(function(l, idx) {
      l.style.color = idx < upTo ? "#f59e0b" : "#d1d5db"
    })
  }

  function resetStars(container) {
    const labels  = Array.from(container.querySelectorAll("label")).reverse()
    const checked = container.querySelector("input[type=radio]:checked")
    const rating  = checked ? parseInt(checked.value) : 0
    labels.forEach(function(l, idx) {
      l.style.color = idx < rating ? "#f59e0b" : "#d1d5db"
    })
  }

  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll("input[name=client_rating]").forEach(function(input) {
      const container = input.closest("div[style]")
      if (container) resetStars(container)
    })
  })
</script>
